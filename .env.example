# Never commit real API keys. Put one or more keys here locally or in Render env vars.
# Separate keys with commas. Argus rotates keys and keeps local RPM/RPD counters per key.
GEMINI_API_KEYS=AIza_example_key_1,AIza_example_key_2
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RPM_LIMIT=10
GEMINI_RPD_LIMIT=250
GEMINI_TIMEOUT_SECONDS=90

DATABASE_PATH=data/argus.db
EVIDENCE_DIR=evidence
EXPORT_DIR=exports

# Optional but recommended on Render if you need true "opens from Kazakhstan" filtering.
# Use an HTTP/SOCKS proxy or private checker located in Kazakhstan.
KZ_PROXY_URL=
KZ_ACCESS_LABEL=Kazakhstan access check

MAX_CANDIDATES_PER_RUN=15
MAX_MIRROR_CHECKS_PER_RUN=6
REQUEST_TIMEOUT_SECONDS=18
SCREENSHOTS_ENABLED=true
OSINT_FEEDS_ENABLED=false

# Optional extra focus. Leave empty for automatic Argus search.
# Example: casino mirror login;betting mirror no license;investment scam reviews
SEED_QUERIES=
